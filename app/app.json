{
  "expo": {
    "name": "OmniSync",
    "slug": "omnisync",
    "scheme": "omnisync",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.omnisync.app"
    },
    "android": {
      "package": "com.omnisync.app",
      "adaptiveIcon": {
        "backgroundColor": "#16111b",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "@sentry/react-native",
      "expo-secure-store",
      "expo-web-browser",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow OmniSync to attach photos to your posts.",
          "cameraPermission": "Allow OmniSync to take photos and videos for your posts."
        }
      ]
    ]
  }
}
