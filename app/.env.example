# Sentry — leave blank to disable error reporting. Set in a local .env (gitignored).
EXPO_PUBLIC_SENTRY_DSN=
# Supabase — public values (anon key is gated by RLS). NOT secrets.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Meta (Facebook) — public app id (the app SECRET stays server-side only).
EXPO_PUBLIC_META_APP_ID=
